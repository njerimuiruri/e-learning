# Backend API URL (Render URL after deployment)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Google OAuth 2.0 Configuration
# Get your credentials from: https://console.cloud.google.com/
# 1. Create a new Google Cloud project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 Web Application credentials
# 4. Add authorized origins: http://localhost:3000
# 5. Add authorized redirect URIs: http://localhost:3000/auth/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
